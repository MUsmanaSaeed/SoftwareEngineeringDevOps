@page "/orders"
@page "/orders/{QueryOrderNo}"
@inject SoftwareEngineeringDevOps.App.Auth.IAuthService AuthService
@inject SoftwareEngineeringDevOps.App.BrickOrders.IBrickOrdersMediator OrdersMediator
@inject SoftwareEngineeringDevOps.App.BrickOrdersReceived.IBrickOrdersReceivedMediator ReceivedMediator
@inject SoftwareEngineeringDevOps.App.Bricks.IBricksMediator BricksMediator
@inject NavigationManager Navigation

@using SoftwareEngineeringDevOps.App.Auth

<PageTitle>Orders</PageTitle>

<div class="split-layout">
    <div class="split-left">
        <div class="panel-header">
            <h3>Orders</h3>
            <div class="panel-header-actions">
                <input class="form-input panel-header-search" placeholder="Search orders..." @bind="ViewModel.OrderGroupsSearchTerm" @bind:event="oninput" />
                @if (global::SoftwareEngineeringDevOps.App.Auth.RoleHelper.CanCreate(ViewModel.CurrentUserRole))
                {
                    <button class="btn btn-add" @onclick="ViewModel.OpenAddOrderModal">
                        <span class="icon">&#xE710;</span>
                    </button>
                }
            </div>
        </div>
        <div class="data-table-container">
            @if (ViewModel.FilteredOrderGroups.Any())
            {
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>Order No</th>
                            <th>Lines</th>
                            <th>Date</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var group in ViewModel.FilteredOrderGroups)
                        {
                            <tr class="@(ViewModel.SelectedOrderNo == group.Key ? "selected" : "")"
                                @onclick="() => HandleSelectGroup(group.Key)">
                                <td>@group.Key</td>
                                <td>@group.Count()</td>
                                <td>@group.First().OrderedDate.ToString("dd/MM/yyyy")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <div class="no-results">
                    <p>No orders found</p>
                </div>
            }
        </div>
    </div>
    <div class="split-right">
        @if (ViewModel.SelectedOrderNo != null)
        {
            <div class="detail-panel">
                <div class="detail-header">
                    <h3>Order: @ViewModel.SelectedOrderNo</h3>
                </div>
                <div class="order-lines">
                    @foreach (var line in ViewModel.SortedSelectedOrderLines)
                    {
                        var brick = ViewModel.Bricks.FirstOrDefault(b => b.Id == line.BrickId);
                        var pct = ViewModel.GetFulfillmentPercentage(line);
                        var totalRcv = ViewModel.GetTotalReceived(line);

                        <div class="order-line-card">
                            <div class="order-line-header" @onclick="() => ViewModel.ToggleRowExpansion(line.Id)" style="cursor: pointer;">
                                <div class="order-line-info">
                                    <strong>@(brick?.Name ?? "Unknown Brick")</strong>
                                    <span class="order-qty">Qty: @line.BricksOrdered</span>
                                    <div class="order-dates">
                                        <span class="order-date">Ordered: @line.OrderedDate.ToString("dd/MM/yyyy")</span>
                                        <span class="order-date">Expected: @line.ExpectedDate.ToString("dd/MM/yyyy")</span>
                                    </div>
                                </div>
                                <div class="order-line-actions">
                                    @if (RoleHelper.CanCreate(ViewModel.CurrentUserRole))
                                    {
                                        <button class="btn btn-add btn-sm" title="Add Received" @onclick="() => ViewModel.OpenAddReceivedModal(line.Id)" @onclick:stopPropagation="true">
                                            <span class="icon">&#xE710;</span>
                                        </button>
                                    }
                                    @if (RoleHelper.CanEdit(ViewModel.CurrentUserRole))
                                    {
                                        <button class="btn btn-edit btn-sm" @onclick="() => ViewModel.OpenEditOrderModal(line)" @onclick:stopPropagation="true">
                                            <span class="icon">&#xE70F;</span>
                                        </button>
                                    }
                                    @if (RoleHelper.CanDelete(ViewModel.CurrentUserRole))
                                    {
                                        <button class="btn btn-delete btn-sm" @onclick="() => ViewModel.OpenDeleteOrderConfirm(line)" @onclick:stopPropagation="true">
                                            <span class="icon">&#xE74D;</span>
                                        </button>
                                    }
                                    <button class="btn btn-sm" @onclick="() => ViewModel.ToggleRowExpansion(line.Id)" @onclick:stopPropagation="true">
                                        <span class="icon">@(ViewModel.IsRowExpanded(line.Id) ? "\uE70E" : "\uE70D")</span>
                                    </button>
                                </div>
                            </div>
                            <div class="progress-bar-container">
                                <div class="progress-bar" style="width: @pct%;">
                                    <span>@totalRcv / @line.BricksOrdered (@pct%)</span>
                                </div>
                            </div>
                            @if (line.CancelledDate != null)
                            {
                                <div class="order-cancelled">Cancelled: @line.CancelledDate.Value.ToString("dd/MM/yyyy")</div>
                            }

                            @if (ViewModel.IsRowExpanded(line.Id))
                            {
                                <div class="received-section">
                                    <h5>Received Batches</h5>
                                    @if (ViewModel.ReceivedByOrderLine.TryGetValue(line.Id, out var receivedItems) && receivedItems.Any())
                                    {
                                        <table class="data-table data-table-sm">
                                            <thead>
                                                <tr>
                                                    <th>Qty</th>
                                                    <th>Date</th>
                                                    <th>By</th>
                                                    <th class="actions-column"></th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @foreach (var rcv in ViewModel.FilterReceivedItems(receivedItems).OrderByDescending(r => r.ReceivedDate))
                                                {
                                                    <tr>
                                                        <td>@rcv.BricksReceived</td>
                                                        <td>@rcv.ReceivedDate.ToString("dd/MM/yyyy")</td>
                                                        <td>@rcv.ReceivedBy.FirstName @rcv.ReceivedBy.LastName</td>
                                                        <td class="row-actions actions-column">
                                                            @if (global::SoftwareEngineeringDevOps.App.Auth.RoleHelper.CanEdit(ViewModel.CurrentUserRole))
                                                            {
                                                                <button class="btn btn-edit btn-xs" @onclick="() => ViewModel.OpenEditReceivedModal(rcv)">
                                                                    <span class="icon">&#xE70F;</span>
                                                                </button>
                                                            }
                                                            @if (global::SoftwareEngineeringDevOps.App.Auth.RoleHelper.CanDelete(ViewModel.CurrentUserRole))
                                                            {
                                                                <button class="btn btn-delete btn-xs" @onclick="() => ViewModel.OpenDeleteReceivedConfirm(rcv)">
                                                                    <span class="icon">&#xE74D;</span>
                                                                </button>
                                                            }
                                                        </td>
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                    }
                                    else
                                    {
                                        <p class="text-muted">No batches received yet.</p>
                                    }
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        }
        else
        {
            <div class="empty-detail">
                <p>Select an order to view details</p>
            </div>
        }
    </div>
</div>

@* Add Order Modal *@
@if (ViewModel.ShowAddOrderModal)
{
    <div class="modal-overlay">
        <div class="modal" @onclick:stopPropagation="true">
            <div class="modal-header">
                <h4>Add Order Line</h4>
                <button class="btn-close" @onclick="ViewModel.CloseAddOrderModal"><span class="icon">&#xE711;</span></button>
            </div>
            <div class="modal-body">
                @if (ViewModel.ValidationErrors.Count > 0)
                {
                    <div class="alert alert-error">
                        <ul>@foreach (var e in ViewModel.ValidationErrors) { <li>@e</li> }</ul>
                    </div>
                }
                <div class="form-group">
                    <label>Order Number</label>
                    <input class="form-input" @bind="ViewModel.NewOrderModel.OrderNo" />
                </div>
                <div class="form-group">
                    <label>Brick</label>
                    <select class="form-input" @bind="ViewModel.NewOrderModel.BrickId">
                        <option value="0">-- Select --</option>
                        @foreach (var b in ViewModel.Bricks)
                        {
                            <option value="@b.Id">@b.Name</option>
                        }
                    </select>
                </div>
                <div class="form-group">
                    <label>Quantity</label>
                    <input class="form-input" type="number" @bind="ViewModel.NewOrderModel.BricksOrdered" />
                </div>
                <div class="form-group">
                    <label>Order Date</label>
                    <input class="form-input" type="date" @bind="ViewModel.NewOrderModel.OrderedDate" />
                </div>
                <div class="form-group">
                    <label>Expected Date</label>
                    <input class="form-input" type="date" @bind="ViewModel.NewOrderModel.ExpectedDate" />
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-cancel" @onclick="ViewModel.CloseAddOrderModal">Cancel</button>
                <button class="btn btn-add" @onclick="HandleAddOrder">Save</button>
            </div>
        </div>
    </div>
}

@* Edit Order Modal *@
@if (ViewModel.ShowEditOrderModal && ViewModel.EditOrderModel != null)
{
    <div class="modal-overlay">
        <div class="modal" @onclick:stopPropagation="true">
            <div class="modal-header">
                <h4>Edit Order Line</h4>
                <button class="btn-close" @onclick="ViewModel.CloseEditOrderModal"><span class="icon">&#xE711;</span></button>
            </div>
            <div class="modal-body">
                @if (ViewModel.ValidationErrors.Count > 0)
                {
                    <div class="alert alert-error">
                        <ul>@foreach (var e in ViewModel.ValidationErrors) { <li>@e</li> }</ul>
                    </div>
                }
                <div class="form-group">
                    <label>Order Number</label>
                    <input class="form-input" value="@ViewModel.EditOrderModel.OrderNo" disabled />
                </div>
                <div class="form-group">
                    <label>Brick</label>
                    <select class="form-input" @bind="ViewModel.EditOrderModel.BrickId">
                        @foreach (var b in ViewModel.Bricks)
                        {
                            <option value="@b.Id">@b.Name</option>
                        }
                    </select>
                </div>
                <div class="form-group">
                    <label>Quantity</label>
                    <input class="form-input" type="number" @bind="ViewModel.EditOrderModel.BricksOrdered" />
                </div>
                <div class="form-group">
                    <label>Order Date</label>
                    <input class="form-input" type="date" @bind="ViewModel.EditOrderModel.OrderedDate" />
                </div>
                <div class="form-group">
                    <label>Expected Date</label>
                    <input class="form-input" type="date" @bind="ViewModel.EditOrderModel.ExpectedDate" />
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-cancel" @onclick="ViewModel.CloseEditOrderModal">Cancel</button>
                <button class="btn btn-edit" @onclick="HandleUpdateOrder">Save</button>
            </div>
        </div>
    </div>
}

@* Delete Order Confirm *@
@if (ViewModel.ShowDeleteOrderConfirm && ViewModel.OrderToDelete != null)
{
    <div class="modal-overlay">
        <div class="modal modal-sm" @onclick:stopPropagation="true">
            <div class="modal-header">
                <h4>Confirm Deletion</h4>
                <button class="btn-close" @onclick="ViewModel.CloseDeleteOrderConfirm"><span class="icon">&#xE711;</span></button>
            </div>
            <div class="modal-body">
                <p>Are you sure you want to delete this order line? All associated received records will also be removed.</p>
            </div>
            <div class="modal-footer">
                <button class="btn btn-cancel" @onclick="ViewModel.CloseDeleteOrderConfirm">Cancel</button>
                <button class="btn btn-delete" @onclick="HandleDeleteOrder">Delete</button>
            </div>
        </div>
    </div>
}

@* Add Received Modal *@
@if (ViewModel.ShowAddReceivedModal)
{
    <div class="modal-overlay">
        <div class="modal" @onclick:stopPropagation="true">
            <div class="modal-header">
                <h4>Add Received Batch</h4>
                <button class="btn-close" @onclick="ViewModel.CloseAddReceivedModal"><span class="icon">&#xE711;</span></button>
            </div>
            <div class="modal-body">
                @if (ViewModel.ValidationErrors.Count > 0)
                {
                    <div class="alert alert-error">
                        <ul>@foreach (var e in ViewModel.ValidationErrors) { <li>@e</li> }</ul>
                    </div>
                }
                <div class="form-group">
                    <label>Quantity Received</label>
                    <input class="form-input" type="number" @bind="ViewModel.NewReceivedModel.BricksReceived" />
                </div>
                <div class="form-group">
                    <label>Received Date</label>
                    <input class="form-input" type="date" @bind="ViewModel.NewReceivedModel.ReceivedDate" />
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-cancel" @onclick="ViewModel.CloseAddReceivedModal">Cancel</button>
                <button class="btn btn-add" @onclick="HandleAddReceived">Save</button>
            </div>
        </div>
    </div>
}

@* Edit Received Modal *@
@if (ViewModel.ShowEditReceivedModal && ViewModel.EditReceivedModel != null)
{
    <div class="modal-overlay">
        <div class="modal" @onclick:stopPropagation="true">
            <div class="modal-header">
                <h4>Edit Received Batch</h4>
                <button class="btn-close" @onclick="ViewModel.CloseEditReceivedModal"><span class="icon">&#xE711;</span></button>
            </div>
            <div class="modal-body">
                @if (ViewModel.ValidationErrors.Count > 0)
                {
                    <div class="alert alert-error">
                        <ul>@foreach (var e in ViewModel.ValidationErrors) { <li>@e</li> }</ul>
                    </div>
                }
                <div class="form-group">
                    <label>Quantity Received</label>
                    <input class="form-input" type="number" @bind="ViewModel.EditReceivedModel.BricksReceived" />
                </div>
                <div class="form-group">
                    <label>Received Date</label>
                    <input class="form-input" type="date" @bind="ViewModel.EditReceivedModel.ReceivedDate" />
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-cancel" @onclick="ViewModel.CloseEditReceivedModal">Cancel</button>
                <button class="btn btn-edit" @onclick="HandleUpdateReceived">Save</button>
            </div>
        </div>
    </div>
}

@* Delete Received Confirm *@
@if (ViewModel.ShowDeleteReceivedConfirm && ViewModel.ReceivedToDelete != null)
{
    <div class="modal-overlay">
        <div class="modal modal-sm" @onclick:stopPropagation="true">
            <div class="modal-header">
                <h4>Confirm Deletion</h4>
                <button class="btn-close" @onclick="ViewModel.CloseDeleteReceivedConfirm"><span class="icon">&#xE711;</span></button>
            </div>
            <div class="modal-body">
                <p>Are you sure you want to delete this received batch record?</p>
            </div>
            <div class="modal-footer">
                <button class="btn btn-cancel" @onclick="ViewModel.CloseDeleteReceivedConfirm">Cancel</button>
                <button class="btn btn-delete" @onclick="HandleDeleteReceived">Delete</button>
            </div>
        </div>
    </div>
}

@code {
    private Components.ViewModels.OrdersViewModel ViewModel { get; set; } = null!;

    [Parameter]
    public string? QueryOrderNo { get; set; }

    [SupplyParameterFromQuery(Name = "action")]
    public string? Action { get; set; }

    protected override async Task OnInitializedAsync()
    {
        ViewModel = new Components.ViewModels.OrdersViewModel(OrdersMediator, ReceivedMediator, BricksMediator, AuthService);
        await ViewModel.LoadOrders();

        if (!string.IsNullOrEmpty(QueryOrderNo))
        {
            await ViewModel.SelectOrderGroup(QueryOrderNo);
        }

        if (Action == "add")
        {
            ViewModel.OpenAddOrderModal();
        }
    }

    private async Task HandleSelectGroup(string orderNo)
    {
        await ViewModel.SelectOrderGroup(orderNo);
        Navigation.NavigateTo($"/orders/{orderNo}", forceLoad: false, replace: true);
    }

    private async Task HandleAddOrder()
    {
        await ViewModel.AddOrder();
    }

    private async Task HandleUpdateOrder()
    {
        await ViewModel.UpdateOrder();
    }

    private async Task HandleDeleteOrder()
    {
        await ViewModel.DeleteOrder();
    }

    private async Task HandleAddReceived()
    {
        await ViewModel.AddReceived();
    }

    private async Task HandleUpdateReceived()
    {
        await ViewModel.UpdateReceived();
    }

    private async Task HandleDeleteReceived()
    {
        await ViewModel.DeleteReceived();
    }
}
