@page "/login"
@layout MainLayout

<PageTitle>Login</PageTitle>

<div class="row justify-content-center mt-5">
    <div class="col-md-4">
        <div class="card shadow-sm">
            <div class="card-body">
                <h3 class="card-title text-center mb-4">Sign In</h3>

                @if (!string.IsNullOrEmpty(_errorMessage))
                {
                    <div class="alert alert-danger" role="alert">@_errorMessage</div>
                }

                <form method="post" @formname="login-form">
                    <AntiforgeryToken />

                    <div class="mb-3">
                        <label for="username" class="form-label">Username</label>
                        <input id="username" name="Input.Username" type="text" class="form-control"
                               value="@Input?.Username" autocomplete="username" required />
                    </div>

                    <div class="mb-3">
                        <label for="password" class="form-label">Password</label>
                        <input id="password" name="Input.Password" type="password" class="form-control"
                               autocomplete="current-password" required />
                    </div>

                    <div class="d-grid">
                        <button type="submit" class="btn btn-primary">Login</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@code {
    [CascadingParameter]
    private HttpContext HttpContext { get; set; } = default!;

    [SupplyParameterFromForm(FormName = "login-form")]
    private LoginInputModel? Input { get; set; }

    [Inject]
    private LoginVM VM { get; set; } = default!;

    [Inject]
    private NavigationManager Navigation { get; set; } = default!;

    [SupplyParameterFromQuery]
    private string? ReturnUrl { get; set; }

    private string? _errorMessage;

    protected override async Task OnInitializedAsync()
    {
        if (HttpContext.Request.Method == HttpMethods.Post && Input?.Username is not null)
        {
            var success = await VM.LoginAsync(Input.Username, Input.Password ?? string.Empty, HttpContext);

            if (success)
            {
                var target = string.IsNullOrWhiteSpace(ReturnUrl) ? "/" : ReturnUrl;
                HttpContext.Response.Redirect(target);
            }
            else
            {
                _errorMessage = VM.ErrorMessage;
            }
        }
    }

    private sealed class LoginInputModel
    {
        public string? Username { get; set; }
        public string? Password { get; set; }
    }
}
