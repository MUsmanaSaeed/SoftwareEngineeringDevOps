@page "/user-management"
@attribute [Authorize]
@rendermode InteractiveServer

<PageTitle>User Management</PageTitle>

@if (VM.IsAccessDenied)
{
    <div class="alert alert-danger mt-4">
        <h4>Access Denied</h4>
        <p>You do not have permission to access this page.</p>
    </div>
}
else
{
    <h1>User Management</h1>

    @if (!string.IsNullOrEmpty(VM.ErrorMessage))
    {
        <div class="alert alert-danger">@VM.ErrorMessage</div>
    }

    @if (!string.IsNullOrEmpty(VM.SuccessMessage))
    {
        <div class="alert alert-success">@VM.SuccessMessage</div>
    }

    <div class="mb-3">
        <button class="btn btn-success" @onclick="VM.PrepareForAdd">+ Add User</button>
    </div>

    @if (VM.IsAddMode || VM.SelectedUser is not null)
    {
        <div class="card mb-4">
            <div class="card-header">
                <strong>@(VM.IsAddMode ? "Add New User" : $"Edit: {VM.SelectedUser!.Username}")</strong>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Username</label>
                        <input type="text" class="form-control" @bind="VM.FormUsername" />
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label">
                            Password
                            @if (!VM.IsAddMode)
                            {
                                <span class="text-muted">(required — sets a new password)</span>
                            }
                        </label>
                        <input type="password" class="form-control" @bind="VM.FormPassword" autocomplete="new-password" />
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label">First Name</label>
                        <input type="text" class="form-control" @bind="VM.FormFirstName" />
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Second Name</label>
                        <input type="text" class="form-control" @bind="VM.FormSecondName" />
                    </div>
                    <div class="col-md-3 mb-3">
                        <div class="form-check mt-4">
                            <input class="form-check-input" type="checkbox"
                                   id="chkIsAdmin"
                                   @bind="VM.FormIsAdmin"
                                   disabled="@(VM.SelectedUser is not null && VM.IsCurrentAdmin(VM.SelectedUser))" />
                            <label class="form-check-label" for="chkIsAdmin">
                                Is Admin
                                @if (VM.SelectedUser is not null && VM.IsCurrentAdmin(VM.SelectedUser))
                                {
                                    <span class="text-muted small">(cannot change own admin flag)</span>
                                }
                            </label>
                        </div>
                    </div>
                    <div class="col-md-3 mb-3">
                        <div class="form-check mt-4">
                            <input class="form-check-input" type="checkbox" id="chkIsEditor" @bind="VM.FormIsEditor" />
                            <label class="form-check-label" for="chkIsEditor">Is Editor</label>
                        </div>
                    </div>
                </div>

                <button class="btn btn-primary me-2" @onclick="SaveAsync">Save</button>
                <button class="btn btn-secondary" @onclick="VM.CancelForm">Cancel</button>
            </div>
        </div>
    }

    <div class="table-responsive">
        <table class="table table-striped table-hover align-middle">
            <thead class="table-dark">
                <tr>
                    <th>Id</th>
                    <th>Username</th>
                    <th>First Name</th>
                    <th>Second Name</th>
                    <th>Admin</th>
                    <th>Editor</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var user in VM.Users)
                {
                    <tr class="@(user.IsDeleted ? "table-secondary text-muted" : "")">
                        <td>@user.Id</td>
                        <td>@user.Username</td>
                        <td>@user.FirstName</td>
                        <td>@user.SecondName</td>
                        <td>@(user.IsAdmin ? "✓" : "–")</td>
                        <td>@(user.IsEditor ? "✓" : "–")</td>
                        <td>
                            @if (user.IsDeleted)
                            {
                                <span class="badge bg-secondary">Disabled</span>
                            }
                            else
                            {
                                <span class="badge bg-success">Active</span>
                            }
                        </td>
                        <td>
                            <button class="btn btn-sm btn-outline-primary me-1"
                                    @onclick="() => VM.SelectForEdit(user)">Edit</button>

                            @if (!user.IsDeleted)
                            {
                                <button class="btn btn-sm btn-outline-danger"
                                        @onclick="() => DeleteAsync(user.Id)">Disable</button>
                            }
                            else
                            {
                                <button class="btn btn-sm btn-outline-success"
                                        @onclick="() => EnableAsync(user.Id)">Enable</button>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@code {
    [CascadingParameter]
    private Task<AuthenticationState> AuthState { get; set; } = default!;

    [Inject]
    private UserManagementVM VM { get; set; } = default!;

    protected override async Task OnInitializedAsync()
    {
        var state = await AuthState;
        await VM.InitializeAsync(state.User);
    }

    private async Task SaveAsync() => await VM.SaveAsync();

    private async Task DeleteAsync(long id) => await VM.DeleteAsync(id);

    private async Task EnableAsync(long id) => await VM.EnableAsync(id);
}
