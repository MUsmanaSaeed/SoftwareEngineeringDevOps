                    <label>Voids (%)</label>
                    <input class="form-input" type="number" min="0" max="100" step="0.1" value="@ViewModel.VoidsPercentInputValue(ViewModel.EditBrickModel.Voids)" @oninput="HandleEditVoidsInput" />
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-cancel" @onclick="ViewModel.CloseEditModal">Cancel</button>
                <button class="btn btn-edit" @onclick="HandleUpdate" disabled="@(!ViewModel.CanSubmitEditBrick)">Save</button>
            </div>
        </div>
    </div>
}

@* Delete Confirm Modal *@
@if (ViewModel.ShowDeleteConfirm && ViewModel.SelectedBrick != null)
{
    <div class="modal-overlay">
        <div class="modal modal-sm" @onclick:stopPropagation="true">
            <div class="modal-header">
                <h4>Confirm Deletion</h4>
                <button class="btn-close" @onclick="ViewModel.CloseDeleteConfirm"><span class="icon">&#xE711;</span></button>
            </div>
            <div class="modal-body">
                @if (!string.IsNullOrEmpty(ViewModel.ErrorMessage))
                {
                    <div class="alert alert-error">@ViewModel.ErrorMessage</div>
                }
                <p>Are you sure you want to delete <strong>@ViewModel.SelectedBrick.Name</strong>?</p>
            </div>
            <div class="modal-footer">
                <button class="btn btn-cancel" @onclick="ViewModel.CloseDeleteConfirm">Cancel</button>
                <button class="btn btn-delete" @onclick="HandleDelete" disabled="@(!string.IsNullOrEmpty(ViewModel.ErrorMessage))">Delete</button>
            </div>
        </div>
    </div>
}

@code {
    [SupplyParameterFromQuery(Name = "action")]
    public string? Action { get; set; }

    [Parameter]
    public long? SelectedId { get; set; }

    protected override async Task OnInitializedAsync()
    {
        await ViewModel.LoadBricks();

        if (SelectedId.HasValue)
        {
            await ViewModel.SelectBrickById(SelectedId.Value);
            if (Action == "edit" && ViewModel.SelectedBrick != null) ViewModel.OpenEditModal(ViewModel.SelectedBrick);
            else if (Action == "delete" && ViewModel.SelectedBrick != null) await ViewModel.OpenDeleteConfirm(ViewModel.SelectedBrick);
        }
        else if (Action == "add")
        {
            ViewModel.OpenAddModal();
        }
    }

    async Task HandleSelect(IBrick brick)
    {
        await ViewModel.SelectBrick(brick);
        Navigation.NavigateTo($"/bricks/{brick.Id}", forceLoad: false, replace: true);
    }

    async Task HandleOpenDelete(IBrick brick)
    {
        await ViewModel.OpenDeleteConfirm(brick);
    }

    async Task HandleAdd()
    {
        var name = ViewModel.NewBrickModel.Name;
        var success = await ViewModel.AddBrick();
        if (success)
        {
            ToastService.Show($"Brick '{name}' created successfully.");
            if (ViewModel.SelectedBrick != null)
            {
                Navigation.NavigateTo($"/bricks/{ViewModel.SelectedBrick.Id}", forceLoad: false, replace: true);
            }
        }
        else
        {
            ToastService.Show("Failed to add brick. Please check the form.", ToastSeverity.Error);
        }
    }

    async Task HandleUpdate()
    {
        var name = ViewModel.EditBrickModel?.Name;
        var success = await ViewModel.UpdateBrick();
        if (success)
        {
            ToastService.Show($"Brick '{name}' updated successfully.");
            if (ViewModel.SelectedBrick != null)
            {
                Navigation.NavigateTo($"/bricks/{ViewModel.SelectedBrick.Id}", forceLoad: false, replace: true);
            }
        }
        else
        {
            ToastService.Show("Failed to update brick. Please check the form.", ToastSeverity.Error);
        }
    }

    async Task HandleDelete()
    {
        var name = ViewModel.SelectedBrick?.Name;
        var success = await ViewModel.DeleteBrick();
        if (success)
        {
            ToastService.Show($"Brick '{name}' deleted.", ToastSeverity.Warning);
            Navigation.NavigateTo("/bricks", forceLoad: false, replace: true);
        }
        else
        {
            ToastService.Show("Failed to delete brick.", ToastSeverity.Error);
        }
    }

    void HandleOrderClick(string orderNo)
    {
        Navigation.NavigateTo($"/orders/{orderNo}");
    }

    void HandleAddNameInput(ChangeEventArgs e)
    {
        ViewModel.NewBrickModel.Name = e.Value?.ToString().ToTitleCase() ?? string.Empty;
        ViewModel.ValidateAddBrickName();
    }

    void HandleAddColourInput(ChangeEventArgs e)
    {
        ViewModel.NewBrickModel.Colour = e.Value?.ToString().ToTitleCase() ?? string.Empty;
    }

    void HandleAddMaterialInput(ChangeEventArgs e)
    {
        ViewModel.NewBrickModel.Material = e.Value?.ToString().ToTitleCase() ?? string.Empty;
    }

    void HandleAddTypeInput(ChangeEventArgs e)
    {
        ViewModel.NewBrickModel.Type = e.Value?.ToString().ToTitleCase() ?? string.Empty;
    }

    Task HandleAddManufacturerChanged(string value)
    {
        ViewModel.SetAddManufacturerFromText(value);
        return Task.CompletedTask;
    }

    void HandleAddPriceInput(ChangeEventArgs e)
    {
        ViewModel.NewBrickModel.Price = BricksViewModel.ParseDecimalInput(e.Value?.ToString());
        ViewModel.ValidateAddNumericInputs();
    }

    void HandleAddStrengthInput(ChangeEventArgs e)
    {
        ViewModel.NewBrickModel.Strength = BricksViewModel.ParseDecimalInput(e.Value?.ToString());
        ViewModel.ValidateAddNumericInputs();
    }

    void HandleAddWidthInput(ChangeEventArgs e)
    {
        ViewModel.NewBrickModel.Width = BricksViewModel.ParseDecimalInput(e.Value?.ToString());
        ViewModel.ValidateAddNumericInputs();
    }

    void HandleAddHeightInput(ChangeEventArgs e)
    {
        ViewModel.NewBrickModel.Height = BricksViewModel.ParseDecimalInput(e.Value?.ToString());
        ViewModel.ValidateAddNumericInputs();
    }

    void HandleAddDepthInput(ChangeEventArgs e)
    {
        ViewModel.NewBrickModel.Depth = BricksViewModel.ParseDecimalInput(e.Value?.ToString());
        ViewModel.ValidateAddNumericInputs();
    }

    void HandleAddVoidsInput(ChangeEventArgs e)
    {
        ViewModel.NewBrickModel.Voids = BricksViewModel.ParseVoidsPercentInput(e.Value?.ToString());
    }

    void HandleEditNameInput(ChangeEventArgs e)
    {
        if (ViewModel.EditBrickModel == null) return;
        ViewModel.EditBrickModel.Name = e.Value?.ToString().ToTitleCase() ?? string.Empty;
        ViewModel.ValidateEditBrickName();
    }

    void HandleEditColourInput(ChangeEventArgs e)
    {
        if (ViewModel.EditBrickModel == null) return;
        ViewModel.EditBrickModel.Colour = e.Value?.ToString().ToTitleCase() ?? string.Empty;
    }

    void HandleEditMaterialInput(ChangeEventArgs e)
    {
        if (ViewModel.EditBrickModel == null) return;
        ViewModel.EditBrickModel.Material = e.Value?.ToString().ToTitleCase() ?? string.Empty;
    }

    void HandleEditTypeInput(ChangeEventArgs e)
    {
        if (ViewModel.EditBrickModel == null) return;
        ViewModel.EditBrickModel.Type = e.Value?.ToString().ToTitleCase() ?? string.Empty;
    }

    Task HandleEditManufacturerChanged(string value)
    {
        ViewModel.SetEditManufacturerFromText(value);
        return Task.CompletedTask;
    }

    void HandleEditPriceInput(ChangeEventArgs e)
    {
        if (ViewModel.EditBrickModel == null) return;
        ViewModel.EditBrickModel.Price = BricksViewModel.ParseDecimalInput(e.Value?.ToString());
        ViewModel.ValidateEditNumericInputs();
    }

    void HandleEditStrengthInput(ChangeEventArgs e)
    {
        if (ViewModel.EditBrickModel == null) return;
        ViewModel.EditBrickModel.Strength = BricksViewModel.ParseDecimalInput(e.Value?.ToString());
        ViewModel.ValidateEditNumericInputs();
    }

    void HandleEditWidthInput(ChangeEventArgs e)
    {
        if (ViewModel.EditBrickModel == null) return;
        ViewModel.EditBrickModel.Width = BricksViewModel.ParseDecimalInput(e.Value?.ToString());
        ViewModel.ValidateEditNumericInputs();
    }

    void HandleEditHeightInput(ChangeEventArgs e)
    {
        if (ViewModel.EditBrickModel == null) return;
        ViewModel.EditBrickModel.Height = BricksViewModel.ParseDecimalInput(e.Value?.ToString());
        ViewModel.ValidateEditNumericInputs();
    }

    void HandleEditDepthInput(ChangeEventArgs e)
    {
        if (ViewModel.EditBrickModel == null) return;
        ViewModel.EditBrickModel.Depth = BricksViewModel.ParseDecimalInput(e.Value?.ToString());
        ViewModel.ValidateEditNumericInputs();
    }

    void HandleEditVoidsInput(ChangeEventArgs e)
    {
        if (ViewModel.EditBrickModel == null) return;
        ViewModel.EditBrickModel.Voids = BricksViewModel.ParseVoidsPercentInput(e.Value?.ToString());
    }
}
