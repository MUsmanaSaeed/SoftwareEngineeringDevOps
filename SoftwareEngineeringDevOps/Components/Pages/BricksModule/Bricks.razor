@page "/bricks"
@page "/bricks/{SelectedId:long}"
@inject SoftwareEngineeringDevOps.App.Auth.IAuthService AuthService
@inject SoftwareEngineeringDevOps.App.Bricks.IBricksMediator BricksMediator
@inject SoftwareEngineeringDevOps.App.Manufacturers.IManufacturersMediator ManufacturersMediator
@inject SoftwareEngineeringDevOps.App.BrickOrders.IBrickOrdersMediator OrdersMediator
@inject NavigationManager Navigation

<PageTitle>Bricks</PageTitle>

@using Components.ViewModels;

<div class="split-layout">
    <div class="split-left">
        <div class="panel-header">
            <h3>Bricks</h3>
            <div class="panel-header-actions">
                <input class="form-input panel-header-search" placeholder="Search bricks..." @bind="ViewModel.BricksSearchTerm" @bind:event="oninput" />
                @if (global::SoftwareEngineeringDevOps.App.Auth.RoleHelper.CanCreate(ViewModel.CurrentUserRole))
                {
                    <button class="btn btn-add" @onclick="ViewModel.OpenAddModal">
                        <span class="icon">&#xE710;</span>
                    </button>
                }
            </div>
        </div>
        <div class="data-table-container">
            @if (ViewModel.FilteredBricks.Any())
            {
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>Name</th>
                            <th>Manufacturer</th>
                            <th>Price</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var brick in ViewModel.FilteredBricks)
                        {
                            <tr class="@(ViewModel.SelectedBrick?.Id == brick.Id ? "selected" : "")"
                                @onclick="() => HandleSelect(brick)">
                                <td>@brick.Name</td>
                                <td>@brick.Manufacturer.Name</td>
                                <td>@ViewModel.FormatPrice(brick.Price)</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <div class="no-results">
                    <p>No bricks found</p>
                </div>
            }
        </div>
    </div>
    <div class="split-right">
        @if (ViewModel.SelectedBrick != null)
        {
            <div class="detail-panel">
                <div class="detail-header">
                    <h3>@ViewModel.SelectedBrick.Name</h3>
                    <div class="detail-actions">
                        @if (global::SoftwareEngineeringDevOps.App.Auth.RoleHelper.CanEdit(ViewModel.CurrentUserRole))
                        {
                            <button class="btn btn-edit" @onclick="() => ViewModel.OpenEditModal(ViewModel.SelectedBrick)">
                                <span class="icon">&#xE70F;</span>
                            </button>
                        }
                        @if (global::SoftwareEngineeringDevOps.App.Auth.RoleHelper.CanDelete(ViewModel.CurrentUserRole))
                        {
                            <button class="btn btn-delete" @onclick="() => HandleOpenDelete(ViewModel.SelectedBrick)">
                                <span class="icon">&#xE74D;</span>
                            </button>
                        }
                    </div>
                </div>
                <div class="detail-body">
                    <div class="detail-row"><span class="label">Price:</span><span>@ViewModel.FormatPrice(ViewModel.SelectedBrick.Price)</span></div>
                    <div class="detail-row"><span class="label">Colour:</span><span>@ViewModel.SelectedBrick.Colour</span></div>
                    <div class="detail-row"><span class="label">Material:</span><span>@ViewModel.SelectedBrick.Material</span></div>
                    <div class="detail-row"><span class="label">Strength:</span><span>@ViewModel.SelectedBrick.Strength N/mm²</span></div>
                    <div class="detail-row"><span class="label">Dimensions:</span><span>@ViewModel.SelectedBrick.Width × @ViewModel.SelectedBrick.Height × @ViewModel.SelectedBrick.Depth mm</span></div>
                    <div class="detail-row"><span class="label">Type:</span><span>@ViewModel.SelectedBrick.Type</span></div>
                    <div class="detail-row"><span class="label">Voids:</span><span>@ViewModel.FormatVoidsPercent(ViewModel.SelectedBrick.Voids)</span></div>
                    <div class="detail-row">
                        <span class="label">Manufacturer:</span>
                        <a href="/manufacturers/@ViewModel.SelectedBrick.Manufacturer.Id">@ViewModel.SelectedBrick.Manufacturer.Name</a>
                    </div>
                </div>
                <div class="detail-section">
                    <div class="detail-section-header">
                        <h4>Orders</h4>
                        @if (ViewModel.SelectedBrickOrders.Any())
                        {
                            <input class="form-input" placeholder="Search orders..." @bind="ViewModel.BrickOrdersSearchTerm" @bind:event="oninput" />
                        }
                    </div>
                    @if (ViewModel.SelectedBrickOrders.Any())
                    {
                        @if (ViewModel.FilteredSelectedBrickOrders.Any())
                        {
                            <table class="data-table data-table-sm">
                                <thead>
                                    <tr>
                                        <th>Order No</th>
                                        <th>Qty</th>
                                        <th>Date</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var order in ViewModel.FilteredSelectedBrickOrders)
                                    {
                                        <tr @onclick="() => HandleOrderClick(order.OrderNo)">
                                            <td>@order.OrderNo</td>
                                            <td>@order.BricksOrdered</td>
                                            <td>@order.OrderedDate.ToString("dd/MM/yyyy")</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        }
                        else
                        {
                            <div class="no-results">
                                <p>No orders found</p>
                            </div>
                        }
                    }
                    else
                    {
                        <p class="text-muted">No orders for this brick.</p>
                    }
                </div>
            </div>
        }
        else
        {
            <div class="empty-detail">
                <p>Select a brick to view details</p>
            </div>
        }
    </div>
</div>

@* Add Brick Modal *@
@if (ViewModel.ShowAddModal)
{
    <div class="modal-overlay">
        <div class="modal" @onclick:stopPropagation="true">
            <div class="modal-header">
                <h4>Add Brick</h4>
                <button class="btn-close" @onclick="ViewModel.CloseAddModal"><span class="icon">&#xE711;</span></button>
            </div>
            <div class="modal-body">
                @if (ViewModel.ValidationErrors.Count > 0)
                {
                    <div class="alert alert-error">
                        <ul>@foreach (var e in ViewModel.ValidationErrors) { <li>@e</li> }</ul>
                    </div>
                }
                @if (!string.IsNullOrWhiteSpace(ViewModel.AddBrickNameValidationMessage))
                {
                    <div class="alert alert-error">@ViewModel.AddBrickNameValidationMessage</div>
                }
                @if (!string.IsNullOrWhiteSpace(ViewModel.AddNumericValidationMessage))
                {
                    <div class="alert alert-error">@ViewModel.AddNumericValidationMessage</div>
                }
                <div class="form-group">
                    <label>Name</label>
                    <input class="form-input" value="@ViewModel.NewBrickModel.Name" @oninput="HandleAddNameInput" />
                </div>
                <div class="form-group">
                    <label>Manufacturer</label>
                    <input class="form-input" placeholder="Search manufacturers..." @bind="ViewModel.ManufacturerSearch" @bind:event="oninput" />
                    <select class="form-input" @bind="ViewModel.NewBrickModel.ManufacturerId">
                        <option value="0">-- Select --</option>
                        @foreach (var m in ViewModel.FilteredManufacturers)
                        {
                            <option value="@m.Id">@m.Name</option>
                        }
                    </select>
                </div>
                <div class="form-group">
                    <label>Price (£)</label>
                    <input class="form-input" type="number" min="0" step="0.01" value="@ViewModel.NewBrickModel.Price" @oninput="HandleAddPriceInput" />
                </div>
                <div class="form-group">
                    <label>Colour</label>
                    <input class="form-input" value="@ViewModel.NewBrickModel.Colour" @oninput="HandleAddColourInput" />
                </div>
                <div class="form-group">
                    <label>Material</label>
                    <input class="form-input" value="@ViewModel.NewBrickModel.Material" @oninput="HandleAddMaterialInput" />
                </div>
                <div class="form-group">
                    <label>Strength (N/mm²)</label>
                    <input class="form-input" type="number" min="0" step="0.1" value="@ViewModel.NewBrickModel.Strength" @oninput="HandleAddStrengthInput" />
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label>Width (mm)</label>
                        <input class="form-input" type="number" min="0" max="10000" step="0.1" value="@ViewModel.NewBrickModel.Width" @oninput="HandleAddWidthInput" />
                    </div>
                    <div class="form-group">
                        <label>Height (mm)</label>
                        <input class="form-input" type="number" min="0" max="10000" step="0.1" value="@ViewModel.NewBrickModel.Height" @oninput="HandleAddHeightInput" />
                    </div>
                    <div class="form-group">
                        <label>Depth (mm)</label>
                        <input class="form-input" type="number" min="0" max="10000" step="0.1" value="@ViewModel.NewBrickModel.Depth" @oninput="HandleAddDepthInput" />
                    </div>
                </div>
                <div class="form-group">
                    <label>Type</label>
                    <input class="form-input" value="@ViewModel.NewBrickModel.Type" @oninput="HandleAddTypeInput" />
                </div>
                <div class="form-group">
                    <label>Voids (%)</label>
                    <input class="form-input" type="number" min="0" max="100" step="0.1" value="@ViewModel.VoidsPercentInputValue(ViewModel.NewBrickModel.Voids)" @oninput="HandleAddVoidsInput" />
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-cancel" @onclick="ViewModel.CloseAddModal">Cancel</button>
                <button class="btn btn-add" @onclick="HandleAdd" disabled="@(!ViewModel.CanSubmitAddBrick)">Save</button>
            </div>
        </div>
    </div>
}

@* Edit Brick Modal *@
