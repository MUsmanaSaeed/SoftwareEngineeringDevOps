        <div class="modal" @onclick:stopPropagation="true">
            <div class="modal-header">
                <h4>Edit Brick</h4>
                <button class="btn-close" @onclick="ViewModel.CloseEditModal"><span class="icon">&#xE711;</span></button>
            </div>
            <div class="modal-body">
                @if (ViewModel.ValidationErrors.Count > 0)
                {
                    <div class="alert alert-error">
                        <ul>@foreach (var e in ViewModel.ValidationErrors) { <li>@e</li> }</ul>
                    </div>
                }
                @if (!string.IsNullOrWhiteSpace(ViewModel.EditBrickNameValidationMessage))
                {
                    <div class="alert alert-error">@ViewModel.EditBrickNameValidationMessage</div>
                }
                @if (!string.IsNullOrWhiteSpace(ViewModel.EditNumericValidationMessage))
                {
