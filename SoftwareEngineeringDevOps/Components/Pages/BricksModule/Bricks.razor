                    </div>
                    <div class="form-group">
                        <label>Depth (mm)</label>
                        <input class="form-input" type="number" min="0" max="10000" step="0.1" value="@ViewModel.EditBrickModel.Depth" @oninput="HandleEditDepthInput" />
                    </div>
                </div>
                <div class="form-group">
                    <label>Type</label>
                    <input class="form-input" value="@ViewModel.EditBrickModel.Type" @oninput="HandleEditTypeInput" />
                </div>
