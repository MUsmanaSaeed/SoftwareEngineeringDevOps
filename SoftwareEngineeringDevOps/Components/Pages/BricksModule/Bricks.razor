                    <input class="form-input" type="number" min="0" step="0.1" value="@ViewModel.EditBrickModel.Strength" @oninput="HandleEditStrengthInput" />
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label>Width (mm)</label>
                        <input class="form-input" type="number" min="0" max="10000" step="0.1" value="@ViewModel.EditBrickModel.Width" @oninput="HandleEditWidthInput" />
                    </div>
