@page "/register"
@layout Layout.AuthLayout
@inject SoftwareEngineeringDevOps.App.Auth.IAuthService AuthService
@inject SoftwareEngineeringDevOps.App.Users.IUsersMediator UsersMediator
@inject SoftwareEngineeringDevOps.Components.ViewModels.RegisterViewModel ViewModel
@inject NavigationManager Navigation

<PageTitle>Register</PageTitle>

<div class="auth-form" @onkeydown="HandleKeyDown">
    <h2>Create Account</h2>

    @if (!string.IsNullOrEmpty(ViewModel.ErrorMessage))
    {
        <div class="alert alert-error">@ViewModel.ErrorMessage</div>
    }

    @if (ViewModel.ValidationErrors.Count > 0)
    {
        <div class="alert alert-error">
            <ul>
                @foreach (var error in ViewModel.ValidationErrors)
                {
                    <li>@error</li>
                }
            </ul>
        </div>
    }

    <div class="form-group">
        <label for="firstname">First Name</label>
        <input id="firstname" type="text" class="form-input" style="text-transform: capitalize;"
               @bind="ViewModel.FirstName"
               @onblur="HandleNameBlur" />
    </div>

    <div class="form-group">
        <label for="lastname">Last Name</label>
        <input id="lastname" type="text" class="form-input" style="text-transform: capitalize;"
               @bind="ViewModel.LastName"
               @onblur="HandleNameBlur" />
    </div>

    <div class="form-group">
        <label for="username">Username</label>
        <input id="username" type="text" class="form-input"
               value="@ViewModel.Username"
               @oninput="HandleUsernameInput" />
    </div>

    <div class="form-group">
        <label for="password">Password</label>
        <input id="password" type="password" class="form-input" @bind="ViewModel.Password" @bind:event="oninput" />
    </div>

    <button class="btn btn-primary btn-full" @onclick="HandleRegister" disabled="@ViewModel.IsLoading">
        @if (ViewModel.IsLoading)
        {
            <span class="loading-spinner-sm"></span>
        }
        else
        {
            <span>Create Account</span>
        }
    </button>

    <div class="auth-switch">
        <span>Already have an account?</span>
        <a href="/login">Sign In</a>
    </div>
</div>

@code {
    protected override async Task OnInitializedAsync()
    {
        await AuthService.GetCurrentUserAsync();

        if (AuthService.IsAuthenticated)
        {
            Navigation.NavigateTo("/", forceLoad: false);
        }
    }

    private async Task HandleRegister()
    {
        ViewModel.FirstName = NormalizeName(ViewModel.FirstName);
        ViewModel.LastName = NormalizeName(ViewModel.LastName);
        await ViewModel.GenerateUsernameAsync();

        var success = await ViewModel.ExecuteRegister();
        if (success)
        {
            Navigation.NavigateTo("/", forceLoad: false);
        }
    }

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !ViewModel.IsLoading)
            await HandleRegister();
    }

    private async Task HandleNameBlur()
    {
        ViewModel.FirstName = NormalizeName(ViewModel.FirstName);
        ViewModel.LastName = NormalizeName(ViewModel.LastName);
        await ViewModel.GenerateUsernameAsync();
    }

    private void HandleUsernameInput(ChangeEventArgs e)
    {
        string value = e.Value?.ToString() ?? string.Empty;
        ViewModel.Username = value;
        // If the user clears the field, allow auto-generation to take over again
        ViewModel.IsUsernameManuallyEdited = !string.IsNullOrEmpty(value);
    }

    private static string NormalizeName(string? value)
    {
        return (value ?? string.Empty).ToTitleCase();
    }
}
