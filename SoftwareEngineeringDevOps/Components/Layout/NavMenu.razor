<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="">App</a>
    </div>
</div>

<input type="checkbox" title="Navigation menu" class="navbar-toggler" />

<div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
    <nav class="nav flex-column">
        <AuthorizeView>
            <Authorized>
                <div class="nav-item px-3 py-2 text-white-50 small">
                    Signed in as <strong class="text-white">@context.User.FindFirst(AppClaims.Username)?.Value</strong>
                </div>

                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="/" Match="NavLinkMatch.All">
                        <span class="bi bi-house-door-fill-nav-menu" aria-hidden="true"></span> Home
                    </NavLink>
                </div>

                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="/profile">
                        <span class="bi bi-person-fill-nav-menu" aria-hidden="true"></span> My Profile
                    </NavLink>
                </div>

                @if (string.Equals(context.User.FindFirst(AppClaims.IsAdmin)?.Value, "True", StringComparison.OrdinalIgnoreCase))
                {
                    <div class="nav-item px-3">
                        <NavLink class="nav-link" href="/user-management">
                            <span class="bi bi-people-fill-nav-menu" aria-hidden="true"></span> User Management
                        </NavLink>
                    </div>
                }

                <div class="nav-item px-3 mt-auto">
                    <div class="nav-link d-flex align-items-center gap-2">
                        <span class="bi bi-circle-half-nav-menu" aria-hidden="true"></span>
                        <button class="btn btn-link nav-link p-0" @onclick="ToggleThemeAsync">
                            @(_isDark ? "Light Mode" : "Dark Mode")
                        </button>
                    </div>
                </div>

                <div class="nav-item px-3">
                    <form action="/auth/logout" method="post" class="d-inline">
                        <AntiforgeryToken />
                        <button type="submit" class="btn btn-link nav-link p-0">
                            <span class="bi bi-box-arrow-left-nav-menu" aria-hidden="true"></span> Logout
                        </button>
                    </form>
                </div>
            </Authorized>
            <NotAuthorized>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="/login">
                        <span class="bi bi-person-nav-menu" aria-hidden="true"></span> Login
                    </NavLink>
                </div>
            </NotAuthorized>
        </AuthorizeView>
    </nav>
</div>

@code {
    [Inject] private IJSRuntime JS { get; set; } = default!;

    private bool _isDark;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _isDark = await JS.InvokeAsync<bool>("appTheme.isDark");
            StateHasChanged();
        }
    }

    private async Task ToggleThemeAsync()
    {
        _isDark = !_isDark;
        await JS.InvokeVoidAsync("appTheme.set", _isDark ? "dark" : "light");
    }
}

