@inherits LayoutComponentBase
@inject SoftwareEngineeringDevOps.App.Auth.IAuthService AuthService
@inject NavigationManager Navigation

@if (!AuthService.IsAuthenticated)
{
    Navigation.NavigateTo($"/login?returnUrl={Uri.EscapeDataString(Navigation.ToBaseRelativePath(Navigation.Uri))}", forceLoad: false);
    return;
}

<div class="app-layout">
    <aside class="side-nav">
        <div class="side-nav-header">
            <img src="logos/acs_logo_white.png" alt="ACS Logo" class="nav-logo logo-dark" />
            <img src="logos/acs_logo_black.png" alt="ACS Logo" class="nav-logo logo-light" />
        </div>
        <nav class="side-nav-menu">
            <NavLink class="nav-item" href="manufacturers" Match="NavLinkMatch.Prefix">
                <span class="icon">&#xE731;</span>
                <span class="nav-text">Manufacturers</span>
            </NavLink>
            <NavLink class="nav-item" href="bricks" Match="NavLinkMatch.Prefix">
                <span class="icon">&#xE80F;</span>
                <span class="nav-text">Bricks</span>
            </NavLink>
            <NavLink class="nav-item" href="brick-orders" Match="NavLinkMatch.Prefix">
                <span class="icon">&#xE719;</span>
                <span class="nav-text">Orders</span>
            </NavLink>
            @if (AuthService.CurrentUser?.IsAdmin == true)
            {
                <NavLink class="nav-item" href="users" Match="NavLinkMatch.Prefix">
                    <span class="icon">&#xE77B;</span>
                    <span class="nav-text">Users</span>
                </NavLink>
            }
        </nav>
        <div class="side-nav-footer">
            <div class="user-info">
                <span class="user-name">@AuthService.CurrentUser?.FirstName @AuthService.CurrentUser?.LastName</span>
            </div>
            <button class="btn-logout" @onclick="HandleLogout">
                <span class="icon">&#xE7E8;</span>
            </button>
        </div>
    </aside>
    <main class="main-content">
        @if (IsLoading)
        {
            <div class="loading-overlay">
                <div class="loading-spinner"></div>
            </div>
        }
        <article class="page-content">
            @Body
        </article>
    </main>
</div>

<ThemeToggle />

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>

@code {
    private bool IsLoading { get; set; }

    protected override async Task OnInitializedAsync()
    {
        await AuthService.GetCurrentUserAsync();
    }

    private async Task HandleLogout()
    {
        await AuthService.LogoutAsync();
        Navigation.NavigateTo("/login", forceLoad: true);
    }
}
